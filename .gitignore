# Fetched truth data is large and reproducible from MANIFEST.yaml; never commit it.
TRUTH/giab/*
TRUTH/clinvar/*
TRUTH/reference/*
TRUTH/fastq/*
!TRUTH/**/.gitkeep
# keep the authoritative manifest and the computed lock
!TRUTH/MANIFEST.yaml
!TRUTH/MANIFEST.lock.yaml
# keep the held-out slice config + immutable manifest + checksum (reviewer-critical)
!TRUTH/clinvar/model_cutoffs.yaml
!TRUTH/clinvar/heldout_manifest.json
!TRUTH/clinvar/heldout_manifest.sha256

RESULTS/*
!RESULTS/.gitkeep
# keep the held-out slice summary reports (small, reviewer-facing)
!RESULTS/exp1_heldout_slice_summary.json
!RESULTS/exp1_heldout_slice_summary.md

__pycache__/
*.pyc
.pytest_cache/
.venv/
.DS_Store
