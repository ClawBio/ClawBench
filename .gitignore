# Fetched truth data is large and reproducible from MANIFEST.yaml; never commit it.
TRUTH/giab/*
TRUTH/clinvar/*
TRUTH/reference/*
TRUTH/fastq/*
!TRUTH/**/.gitkeep
# keep the authoritative manifest and the computed lock
!TRUTH/MANIFEST.yaml
!TRUTH/MANIFEST.lock.yaml
# keep the held-out slice config + immutable manifest + checksum (reviewer-critical)
!TRUTH/clinvar/model_cutoffs.yaml
!TRUTH/clinvar/heldout_manifest.json
!TRUTH/clinvar/heldout_manifest.sha256
# keep the qualification panel + Tier-A pilot selection
!TRUTH/clinvar/qualification_panel_v1.json
!TRUTH/clinvar/pilot_tier_a_v1.json

RESULTS/*
!RESULTS/.gitkeep
# keep the held-out slice summary reports (small, reviewer-facing)
!RESULTS/exp1_heldout_slice_summary.json
!RESULTS/exp1_heldout_slice_summary.md
!RESULTS/exp1_cutoff_sensitivity.json
!RESULTS/exp1_cutoff_sensitivity.md
!RESULTS/exp1_model_cutoffs_evidence.md
!RESULTS/.model_cutoffs_research.json
!RESULTS/exp1_qualification_panel_summary.md

__pycache__/
*.pyc
.pytest_cache/
.venv/
.DS_Store
!RESULTS/exp1_pilot_endpoints.json
!RESULTS/exp1_pilot_endpoints.md
!RESULTS/exp1_pilot_verdict.md
!RESULTS/pilot_runs.jsonl
!RESULTS/exp1_pilot_v2_verdict.md
!RESULTS/pilot_v2_runs.jsonl
!RESULTS/exp1_points_decomposition.md
!RESULTS/exp1_points_decomposition.json
!RESULTS/exp1_combiner_breadth.md
!RESULTS/exp1_attribution.json
!RESULTS/tier_b_probe_runs.jsonl
!TRUTH/clinvar/tier_b_probe_v1.json
# acquisition arm (Exp 1): frozen probe + oracle cache, runs, and analysis (reviewer-critical)
!TRUTH/clinvar/acquisition_probe_v1.json
!TRUTH/clinvar/acquisition_cache_v1.json
!RESULTS/acquisition_probe_runs.jsonl
!RESULTS/exp1_acquisition.md
!RESULTS/exp1_acquisition_analysis.json
